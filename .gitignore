# Create a Node.js .gitignore file
@'
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov

# Environment variables
.env
.env.local
.env.production

# Logs
logs
*.log

# Build outputs
dist/
build/
.nyc_output
.next/
.nuxt/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history
'@ | Set-Content .gitignore